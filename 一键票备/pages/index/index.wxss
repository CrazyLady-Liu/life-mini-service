.container {
  padding-bottom: 200rpx;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.batch-btn {
  font-size: 28rpx;
  color: #1890ff;
  padding: 10rpx 20rpx;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
}

.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.batch-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selected-count {
  font-size: 26rpx;
  color: #999;
}

.batch-action-btn {
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 6rpx;
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
  margin: 0;
}

.batch-action-btn::after {
  border: none;
}

.batch-action-btn.delete {
  background: #fff1f0;
  color: #ff4d4f;
  border-color: #ffccc7;
}

.empty {
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.invoice-card {
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.invoice-card.default-card {
  border-left: 8rpx solid #1890ff;
  background: linear-gradient(to right, #f0f8ff 0%, #ffffff 30%);
}

.select-checkbox {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  z-index: 10;
}

.select-checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-right: 60rpx;
}

.company-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
}

.tags {
  flex-shrink: 0;
}

.tag-primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}

.info-item {
  display: flex;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.info-label {
  color: #999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  word-break: break-all;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-wrap: wrap;
}

.action-btn {
  font-size: 26rpx;
  border-radius: 6rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.copy-btn {
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}

.default-btn {
  background: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.edit-btn {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.delete-btn {
  background: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.add-section {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 999;
}

.add-btn {
  width: 100%;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.4);
  line-height: 1.5;
}
