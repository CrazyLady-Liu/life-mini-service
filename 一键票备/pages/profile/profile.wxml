<view class="container">
  <view class="user-card">
    <view class="avatar-wrapper">
      <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view wx:else class="avatar default-avatar">👤</view>
    </view>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || '用户'}}</view>
      <view class="phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</view>
      <view class="login-type">
        <text wx:if="{{userInfo.loginType === 'wechat'}}" class="login-type-tag wechat">💬 微信登录</text>
        <text wx:else class="login-type-tag phone">📱 手机号登录</text>
      </view>
    </view>
  </view>

  <view class="card stats-card">
    <view class="stats-title">数据总览</view>
    <view class="stats-content">
      <view class="stats-item">
        <view class="stats-number">{{invoiceCount}}</view>
        <view class="stats-label">抬头数量</view>
      </view>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="onExport">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出抬头数据</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onClearAll">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清空所有数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-section">
    <button class="btn-danger logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>
