<view class="container">
  <view class="card form-card">
    <view class="form-item">
      <text class="form-label required">公司名称</text>
      <input 
        class="form-input" 
        placeholder="请输入公司名称"
        value="{{form.companyName}}"
        data-field="companyName"
        bindinput="onInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label required">纳税人识别号</text>
      <input 
        class="form-input" 
        placeholder="请输入纳税人识别号"
        value="{{form.taxNumber}}"
        data-field="taxNumber"
        bindinput="onInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">地址</text>
      <input 
        class="form-input" 
        placeholder="请输入地址（选填）"
        value="{{form.address}}"
        data-field="address"
        bindinput="onInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">电话</text>
      <input 
        class="form-input" 
        placeholder="请输入电话（选填）"
        value="{{form.phone}}"
        data-field="phone"
        bindinput="onInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">开户行</text>
      <input 
        class="form-input" 
        placeholder="请输入开户行（选填）"
        value="{{form.bank}}"
        data-field="bank"
        bindinput="onInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">账号</text>
      <input 
        class="form-input" 
        placeholder="请输入账号（选填）"
        value="{{form.account}}"
        data-field="account"
        bindinput="onInput"
      />
    </view>

    <view class="form-item switch-item">
      <text class="form-label">设为常用</text>
      <switch 
        checked="{{form.isDefault}}" 
        color="#1890ff"
        bindchange="onSwitchChange"
      />
    </view>
  </view>

  <view class="save-section">
    <button class="btn-primary save-btn" hover-class="btn-hover" catchtap="onSave" loading="{{saving}}" disabled="{{saving}}">
      {{saving ? '保存中...' : '一键保存'}}
    </button>
  </view>
</view>
