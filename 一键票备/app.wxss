page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
  min-height: 88rpx;
  line-height: 1.4;
}

.btn-primary::after {
  border: none;
}

.btn-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-danger {
  background-color: #ff4d4f;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  border: none;
}

.btn-danger::after {
  border: none;
}

.btn-default {
  background-color: #ffffff;
  color: #333333;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}

.btn-default::after {
  border: none;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 30rpx;
  background-color: #fafafa;
}

.form-input:focus {
  border-color: #1890ff;
  background-color: #ffffff;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background-color: #e6f7ff;
  color: #1890ff;
}

.tag-warning {
  background-color: #fff7e6;
  color: #fa8c16;
}
