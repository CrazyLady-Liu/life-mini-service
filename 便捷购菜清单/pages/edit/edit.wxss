.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-group {
  margin-bottom: 36rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.category-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 32rpx;
  background: #f7f7f7;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.cat-icon {
  font-size: 32rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
  font-size: 34rpx;
  border-radius: 48rpx;
  border: none;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

.save-btn::after {
  border: none;
}

.delete-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 34rpx;
  border-radius: 48rpx;
  border: 2rpx solid #ffccc7;
  text-align: center;
}

.delete-btn::after {
  border: none;
}
