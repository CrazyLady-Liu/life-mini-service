.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats {
  margin-bottom: 20rpx;
}

.stats-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

.header-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  width: 100%;
}

.action-btn {
  flex: 1;
  max-width: 240rpx;
  font-size: 26rpx;
  padding: 14rpx 0;
  line-height: 1.4;
  border-radius: 40rpx;
  background: #f6f6f6;
  color: #666;
  margin: 0;
  text-align: center;
}

.action-btn::after {
  border: none;
}

.action-btn.danger {
  background: #fff5f5;
  color: #ff4d4f;
}

.quick-tags {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tags-title {
  font-size: 28rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.tags-row {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.quick-tag {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  background: #fafafa;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.quick-tag:active {
  transform: scale(0.96);
  background: #f0f0f0;
}

.tag-icon {
  font-size: 52rpx;
  margin-bottom: 10rpx;
}

.tag-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.list-container {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 28rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
  text-align: center;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
  text-align: center;
}

.shopping-list {
  padding: 0;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.2s;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item.checked {
  opacity: 0.5;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #52c41a;
  border-color: #52c41a;
}

.check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.item-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.list-item.checked .item-name {
  text-decoration: line-through;
}

.item-category {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.item-meta {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.item-quantity,
.item-remark {
  font-size: 24rpx;
  color: #999;
}

.item-actions {
  padding: 16rpx;
  margin-left: 16rpx;
}

.edit-icon {
  font-size: 34rpx;
}

.add-btn-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #fff 60%, rgba(255, 255, 255, 0.9) 80%, transparent);
  box-sizing: border-box;
}

.add-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

.add-btn::after {
  border: none;
}

.add-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.add-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 85vh;
  overflow-y: auto;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.panel-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
  line-height: 1;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.category-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 28rpx;
  background: #f7f7f7;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.cat-icon {
  font-size: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  margin-top: 24rpx;
  text-align: center;
}

.submit-btn::after {
  border: none;
}
