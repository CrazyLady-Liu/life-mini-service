page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.5;
}
.container {
  padding: 24rpx;
}
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}
.btn-primary {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: #fff;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-secondary {
  background: #f9fafb;
  color: #1f2937;
}
.btn-secondary:active {
  background: #e5e7eb;
}
.btn-ghost {
  background: transparent;
  color: #6366f1;
  border: 2rpx solid #6366f1;
}
.btn-ghost:active {
  background: rgba(99, 102, 241, 0.1);
}
.flex {
  display: flex;
}
.flex-col {
  flex-direction: column;
}
.items-center {
  align-items: center;
}
.justify-center {
  justify-content: center;
}
.justify-between {
  justify-content: space-between;
}
.text-center {
  text-align: center;
}
.text-primary {
  color: #6366f1;
}
.text-secondary {
  color: #6b7280;
}
.text-success {
  color: #10b981;
}
.font-bold {
  font-weight: 600;
}
.font-medium {
  font-weight: 500;
}
.text-sm {
  font-size: 24rpx;
}
.text-base {
  font-size: 28rpx;
}
.text-lg {
  font-size: 32rpx;
}
.text-xl {
  font-size: 40rpx;
}
.text-2xl {
  font-size: 48rpx;
}
.mt-2 {
  margin-top: 16rpx;
}
.mt-4 {
  margin-top: 32rpx;
}
.mb-2 {
  margin-bottom: 16rpx;
}
.mb-4 {
  margin-bottom: 32rpx;
}
.w-full {
  width: 100%;
