.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 24rpx;
}

.user-info .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-info .desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  padding: 30rpx 20rpx 0;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.setting-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.danger .setting-name {
  color: #f44336;
}

.setting-info {
  flex: 1;
}

.setting-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  color: #ccc;
  font-size: 36rpx;
}

.remind-options {
  display: flex;
  gap: 12rpx;
}

.remind-option {
  padding: 10rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.remind-option.active {
  background-color: #e8f5e9;
  color: #4CAF50;
  border-color: #4CAF50;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.member-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.delete-member {
  font-size: 26rpx;
  color: #f44336;
  padding: 8rpx 20rpx;
}

.add-member {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 30rpx;
  font-size: 28rpx;
  color: #4CAF50;
  border-top: 1rpx solid #f0f0f0;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.footer {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #ccc;
}
