.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.member-filter {
  background-color: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.member-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.member-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.member-item.active {
  background-color: #e3f2fd;
  color: #2196F3;
}

.stats-bar {
  display: flex;
  background-color: #fff;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2196F3;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.records-container {
  padding: 0 20rpx;
}

.date-group {
  margin-bottom: 30rpx;
}

.date-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.date-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.record-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.user-tag {
  background-color: #e3f2fd;
  color: #2196F3;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.record-body {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #999;
  min-width: 100rpx;
}

.value {
  color: #333;
  flex: 1;
}

.record-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.delete-btn {
  font-size: 26rpx;
  color: #f44336;
  padding: 8rpx 24rpx;
}

.empty {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 110rpx;
  height: 110rpx;
  background-color: #2196F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(33, 150, 243, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  margin-top: -6rpx;
}
