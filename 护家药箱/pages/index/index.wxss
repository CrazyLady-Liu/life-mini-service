.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  padding: 40rpx 30rpx 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome .greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.welcome .subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.add-btn {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  color: #fff;
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.add-btn .plus {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.remind-section {
  margin: -30rpx 20rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.title-icon {
  margin-right: 8rpx;
}

.count {
  margin-left: auto;
  font-size: 24rpx;
  color: #ff9800;
  background-color: #fff3e0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.remind-banner {
  max-height: 300rpx;
  overflow-y: auto;
}

.remind-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.remind-item:last-child {
  border-bottom: none;
}

.remind-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.remind-info {
  flex: 1;
}

.remind-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.remind-text {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.stats-section {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-card:first-child {
  margin-left: 0;
}

.stat-card:last-child {
  margin-right: 0;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-number.total {
  color: #2196F3;
}

.stat-number.normal {
  color: #4CAF50;
}

.stat-number.expiring {
  color: #ff9800;
}

.stat-number.expired {
  color: #f44336;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.section {
  padding: 0 20rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.more {
  font-size: 26rpx;
  color: #4CAF50;
}

.empty {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}
