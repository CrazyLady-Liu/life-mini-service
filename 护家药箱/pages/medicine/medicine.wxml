<view class="page">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索药品名称..."
      value="{{searchKeyword}}"
      bindinput="onSearch"
      confirm-type="search"
    />
  </view>

  <view class="filter-tabs">
    <view
      class="tab-item {{currentTab === 'all' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="all"
    >
      全部
      <text class="tab-count" wx:if="{{totalCount > 0}}">{{totalCount}}</text>
    </view>
    <view
      class="tab-item {{currentTab === 'normal' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="normal"
    >
      正常
      <text class="tab-count" wx:if="{{normalCount > 0}}">{{normalCount}}</text>
    </view>
    <view
      class="tab-item {{currentTab === 'expiring' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="expiring"
    >
      临期
      <text class="tab-count" wx:if="{{expiringCount > 0}}">{{expiringCount}}</text>
    </view>
    <view
      class="tab-item {{currentTab === 'expired' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="expired"
    >
      过期
      <text class="tab-count" wx:if="{{expiredCount > 0}}">{{expiredCount}}</text>
    </view>
  </view>

  <view class="category-filter" wx:if="{{categories.length > 0}}">
    <scroll-view scroll-x="true" class="category-scroll">
      <view
        class="category-item {{currentCategory === 'all' ? 'active' : ''}}"
        bindtap="selectCategory"
        data-category="all"
      >
        全部类别
      </view>
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-item {{currentCategory === item ? 'active' : ''}}"
        bindtap="selectCategory"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </scroll-view>
  </view>

  <view class="medicine-list" wx:if="{{filteredMedicines.length > 0}}">
    <medicine-card
      wx:for="{{filteredMedicines}}"
      wx:key="id"
      medicine="{{item}}"
      show-actions="{{true}}"
      remind-days="{{remindDays}}"
      bind:edit="editMedicine"
      bind:delete="deleteMedicine"
      bind:cardtap="viewMedicine"
    />
  </view>

  <view class="empty" wx:else>
    <view class="empty-icon">💊</view>
    <view class="empty-text">
      {{searchKeyword ? '未找到相关药品' : '暂无药品'}}
    </view>
    <view class="empty-desc">
      {{searchKeyword ? '试试其他关键词' : '点击下方按钮添加药品'}}
    </view>
    <view class="btn-primary empty-btn" bindtap="goToAdd" wx:if="{{!searchKeyword}}">
      添加药品
    </view>
  </view>

  <view class="fab" bindtap="goToAdd">
    <text class="fab-icon">+</text>
  </view>
</view>
