<view class="page">
  <view class="form-section">
    <view class="form-item">
      <view class="label">药品名称 <text class="required">*</text></view>
      <input
        class="input"
        placeholder="请输入药品名称"
        value="{{form.name}}"
        bindinput="onInput"
        data-field="name"
      />
    </view>

    <view class="form-item">
      <view class="label">药品类别 <text class="required">*</text></view>
      <view class="category-list">
        <view
          wx:for="{{categories}}"
          wx:key="*this"
          class="category-tag {{form.category === item ? 'active' : ''}}"
          bindtap="selectCategory"
          data-category="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="label">规格</view>
      <input
        class="input"
        placeholder="如：0.5g×24片/盒"
        value="{{form.specification}}"
        bindinput="onInput"
        data-field="specification"
      />
    </view>

    <view class="form-row">
      <view class="form-item flex-1">
        <view class="label">数量 <text class="required">*</text></view>
        <input
          class="input"
          type="number"
          placeholder="数量"
          value="{{form.quantity}}"
          bindinput="onInput"
          data-field="quantity"
        />
      </view>
      <view class="form-item flex-1">
        <view class="label">单位</view>
        <picker
          mode="selector"
          range="{{units}}"
          value="{{unitIndex}}"
          bindchange="onUnitChange"
        >
          <view class="picker">
            {{units[unitIndex]}}
            <text class="arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <view class="label">有效期至 <text class="required">*</text></view>
      <picker
        mode="date"
        value="{{form.expiryDate}}"
        bindchange="onDateChange"
      >
        <view class="picker">
          {{form.expiryDate || '请选择有效期'}}
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">存放位置</view>
      <input
        class="input"
        placeholder="如：客厅药箱、卧室抽屉等"
        value="{{form.location}}"
        bindinput="onInput"
        data-field="location"
      />
    </view>

    <view class="form-item">
      <view class="label">备注</view>
      <textarea
        class="textarea"
        placeholder="添加备注信息"
        value="{{form.remark}}"
        bindinput="onInput"
        data-field="remark"
        maxlength="200"
        auto-height
      />
    </view>
  </view>

  <view class="actions">
    <view class="btn-cancel" bindtap="goBack" wx:if="{{isEdit}}">取消</view>
    <view class="btn-submit" bindtap="submit">
      {{isEdit ? '保存修改' : '添加药品'}}
    </view>
  </view>
</view>
