.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 10rpx 0;
}

.form-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-row {
  display: flex;
  padding: 0 30rpx;
}

.form-row .form-item {
  padding: 24rpx 0;
}

.form-row .form-item:first-child {
  margin-right: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: #f44336;
}

.input {
  font-size: 30rpx;
  color: #333;
  padding: 0;
}

.input::placeholder {
  color: #ccc;
}

.textarea {
  font-size: 30rpx;
  color: #333;
  width: 100%;
  min-height: 80rpx;
  padding: 0;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-tag {
  padding: 12rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.category-tag.active {
  background-color: #e8f5e9;
  color: #4CAF50;
  border-color: #4CAF50;
}

.picker {
  font-size: 30rpx;
  color: #333;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker .arrow {
  color: #ccc;
  font-size: 36rpx;
}

.flex-1 {
  flex: 1;
}

.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-submit {
  flex: 1;
  background-color: #4CAF50;
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
  padding: 28rpx 48rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
}
