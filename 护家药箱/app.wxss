page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 48rpx;
  border: none;
}

.btn-primary:active {
  background-color: #45a049;
}

.btn-danger {
  background-color: #f44336;
  color: #fff;
  border-radius: 48rpx;
  border: none;
}

.btn-warning {
  background-color: #ff9800;
  color: #fff;
  border-radius: 48rpx;
  border: none;
}

.text-muted {
  color: #999;
}

.text-danger {
  color: #f44336;
}

.text-warning {
  color: #ff9800;
}

.text-success {
  color: #4CAF50;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.p-20 {
  padding: 20rpx;
}

.text-center {
  text-align: center;
}

.empty {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}
