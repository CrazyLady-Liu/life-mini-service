.tabs {
  display: flex;
  background: #fff;
  margin: -20rpx -20rpx 30rpx;
  padding: 0 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.order-item {
  margin-bottom: 24rpx;
}

.order-header {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
}

.order-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.label {
  width: 140rpx;
  color: #999;
}

.order-footer {
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cost {
  font-size: 30rpx;
  color: #1890ff;
  font-weight: 500;
}

.report-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #1890ff;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
  background: #fff;
}
