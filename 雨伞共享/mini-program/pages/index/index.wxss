.header-card {
  margin-top: 20rpx;
}

.user-info {
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.credit {
  font-size: 26rpx;
  color: #666;
}

.deposit {
  flex-direction: column;
  text-align: right;
}

.deposit-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.scan-section {
  margin: 40rpx 0;
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  font-size: 36rpx;
  border-radius: 16rpx;
}

.scan-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.order-item {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.order-item text:first-child {
  width: 160rpx;
}

.return-btn {
  margin-top: 24rpx;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  margin: 40rpx 0 20rpx;
}

.station-info {
  align-items: center;
}

.station-name {
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.station-address {
  color: #999;
}

.available {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}
