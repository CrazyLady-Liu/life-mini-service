<view class="container">
  <view class="user-header card">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
      <view class="phone text-small text-secondary">{{userInfo.phone || '未绑定手机'}}</view>
    </view>
  </view>

  <view class="deposit-card card">
    <view class="deposit-header flex flex-between">
      <text>押金</text>
      <text class="deposit-amount text-primary">¥{{userInfo.deposit}}</text>
    </view>
    <view class="deposit-actions flex">
      <button 
        class="action-btn flex-1" 
        bindtap="rechargeDeposit"
        disabled="{{userInfo.deposit >= 99}}"
      >充值押金</button>
      <button 
        class="action-btn flex-1" 
        bindtap="withdrawDeposit"
        disabled="{{userInfo.deposit <= 0}}"
      >退还押金</button>
    </view>
    <view class="free-tip text-small text-secondary">
      信用分 {{userInfo.creditScore}} 分，{{userInfo.creditScore >= 650 ? '已享受免押金' : '650分以上可免押金'}}
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="toOrders">
      <text>我的订单</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="toReport">
      <text>故障报修</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>使用帮助</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>关于我们</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
