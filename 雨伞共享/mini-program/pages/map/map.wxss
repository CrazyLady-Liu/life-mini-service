.map-container {
  height: 100vh;
  position: relative;
}

.map {
  width: 100%;
  height: 100%;
}

.station-detail {
  position: absolute;
  bottom: 30rpx;
  left: 20rpx;
  right: 20rpx;
  margin: 0;
}

.station-name {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.station-address {
  margin-bottom: 20rpx;
}

.station-stats {
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.actions {
  gap: 16rpx;
}

.action-btn {
  padding: 20rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid #d9d9d9;
  background: #fff;
}

.action-btn-primary {
  background: #1890ff;
  color: #fff;
  border: none;
}
