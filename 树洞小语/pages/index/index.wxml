<view class="container">
  <view class="header">
    <view class="title-section">
      <text class="main-title">树洞广场</text>
      <text class="sub-title">说出你的心事，这里有人倾听</text>
    </view>
  </view>

  <view class="filter-tabs">
    <view 
      wx:for="{{moodFilters}}" 
      wx:key="id"
      class="filter-tab {{currentFilter === item.id ? 'active' : ''}}"
      bindtap="handleFilter"
      data-id="{{item.id}}"
    >
      <text class="filter-emoji">{{item.emoji}}</text>
      <text class="filter-name">{{item.name}}</text>
    </view>
  </view>

  <view class="waterfall">
    <view class="waterfall-column">
      <view 
        wx:for="{{leftPosts}}" 
        wx:key="id" 
        class="post-card"
        bindtap="handlePostClick"
        data-post="{{item}}"
      >
        <view class="card-header">
          <view class="avatar" style="background: {{item.avatarColor}}">
            <text>{{item.nicknameFirst}}</text>
          </view>
          <view class="user-info">
            <text class="nickname">{{item.nickname}}</text>
            <text class="time">{{item.timeText}}</text>
          </view>
        </view>
        
        <view class="mood-tag" style="background: {{item.moodColor}}">
          <text class="emoji">{{item.moodEmoji}}</text>
          <text>{{item.moodName}}</text>
        </view>
        
        <text class="post-content">{{item.content}}</text>
        
        <view class="card-footer">
          <view class="action-item {{item.isLiked ? 'liked' : ''}}" catchtap="handleLike" data-id="{{item.id}}">
            <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
            <text class="action-count">{{item.likes}}</text>
          </view>
          <view class="action-item" catchtap="handleComment" data-post="{{item}}">
            <text class="action-icon">💬</text>
            <text class="action-count">{{item.commentCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <view class="waterfall-column">
      <view 
        wx:for="{{rightPosts}}" 
        wx:key="id" 
        class="post-card"
        bindtap="handlePostClick"
        data-post="{{item}}"
      >
        <view class="card-header">
          <view class="avatar" style="background: {{item.avatarColor}}">
            <text>{{item.nicknameFirst}}</text>
          </view>
          <view class="user-info">
            <text class="nickname">{{item.nickname}}</text>
            <text class="time">{{item.timeText}}</text>
          </view>
        </view>
        
        <view class="mood-tag" style="background: {{item.moodColor}}">
          <text class="emoji">{{item.moodEmoji}}</text>
          <text>{{item.moodName}}</text>
        </view>
        
        <text class="post-content">{{item.content}}</text>
        
        <view class="card-footer">
          <view class="action-item {{item.isLiked ? 'liked' : ''}}" catchtap="handleLike" data-id="{{item.id}}">
            <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
            <text class="action-count">{{item.likes}}</text>
          </view>
          <view class="action-item" catchtap="handleComment" data-post="{{item}}">
            <text class="action-icon">💬</text>
            <text class="action-count">{{item.commentCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{filteredPosts.length === 0}}" class="empty-state">
    <text class="empty-emoji">🌳</text>
    <text class="empty-text">这里还没有心事哦</text>
    <text class="empty-hint">快来做第一个分享的人吧～</text>
    <button class="go-publish-btn" bindtap="goToPublish">去发布</button>
    <button class="test-btn" bindtap="restoreData">恢复示例数据</button>
  </view>

  <view wx:if="{{filteredPosts.length > 0}}" class="test-bar">
    <button class="test-btn-small" bindtap="testEmptyState">🧪 测试空状态</button>
  </view>

  <view class="publish-fab" bindtap="goToPublish">
    <text class="fab-icon">✍️</text>
  </view>
</view>

<comment-modal 
  visible="{{commentModalVisible}}" 
  post="{{selectedPost}}"
  bind:close="handleCloseComment"
  bind:commented="handleCommented"
/>
