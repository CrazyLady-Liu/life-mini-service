<view class="container">
  <view class="publish-card">
    <view class="card-header">
      <view class="avatar-preview" style="background: {{previewAvatar}}">
        <text>{{previewNickname.charAt(0)}}</text>
      </view>
      <view class="user-preview">
        <text class="preview-nickname">{{previewNickname}}</text>
        <text class="preview-tip">匿名发布中，你的身份将被保护</text>
      </view>
      <view class="refresh-btn" bindtap="refreshIdentity">
        <text>🔄</text>
      </view>
    </view>

    <view class="input-section">
      <textarea 
        class="content-input"
        placeholder="在这里写下你的心事或吐槽..."
        placeholder-class="input-placeholder"
        value="{{content}}"
        bindinput="handleInput"
        maxlength="500"
        auto-height
        show-confirm-bar="{{false}}"
      />
      <view class="char-count">{{content.length}}/500</view>
    </view>

    <view class="mood-section">
      <text class="section-title">选择心情标签</text>
      <view class="mood-tags">
        <view 
          wx:for="{{moodTags}}" 
          wx:key="id"
          class="mood-tag-item {{selectedMood === item.id ? 'selected' : ''}}"
          style="{{selectedMood === item.id ? 'background: ' + item.color + '; border-color: ' + item.color : ''}}"
          bindtap="selectMood"
          data-id="{{item.id}}"
        >
          <text class="tag-emoji">{{item.emoji}}</text>
          <text class="tag-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="tips-section">
      <view class="tip-item">
        <text class="tip-icon">🔒</text>
        <text class="tip-text">你的发布完全匿名，无需担心隐私泄露</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">💚</text>
        <text class="tip-text">请友善发言，传递温暖与正能量</text>
      </view>
    </view>

    <button 
      class="publish-btn {{canPublish ? '' : 'disabled'}}"
      bindtap="handlePublish"
      disabled="{{!canPublish}}"
    >
      <text class="btn-icon">🌱</text>
      <text>一键匿名发布</text>
    </button>
  </view>
</view>
