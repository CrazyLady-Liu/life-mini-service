.container {
  padding: 24rpx;
  min-height: 100vh;
}

.publish-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.user-preview {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.preview-nickname {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.preview-tip {
  font-size: 24rpx;
  color: #999;
}

.refresh-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 28rpx;
}

.input-section {
  position: relative;
  margin-bottom: 32rpx;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  padding: 0;
  box-sizing: border-box;
}

.input-placeholder {
  color: #ccc;
}

.char-count {
  position: absolute;
  right: 0;
  bottom: -8rpx;
  font-size: 24rpx;
  color: #ccc;
}

.mood-section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.mood-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mood-tag-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  transition: all 0.2s;
}

.mood-tag-item.selected {
  color: #fff;
  border: 2rpx solid transparent;
}

.tag-emoji {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.tips-section {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.publish-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #6B8E9F 0%, #8FB0C1 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(107, 142, 159, 0.3);
}

.publish-btn.disabled {
  background: #ccc;
  box-shadow: none;
  color: #fff;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
