<view class="container">
  <view class="header">
    <view class="user-card">
      <view class="user-avatar">
        <text class="avatar-icon">🌳</text>
      </view>
      <view class="user-info">
        <text class="user-title">我的树洞</text>
        <text class="user-desc">共发布 {{myPosts.length}} 条心事</text>
      </view>
      <view class="stats-badge">
        <text class="stats-num">{{myPosts.length}}</text>
        <text class="stats-label">条</text>
      </view>
    </view>
  </view>

  <view class="posts-section">
    <view wx:if="{{myPosts.length === 0}}" class="empty-state">
      <text class="empty-emoji">📝</text>
      <text class="empty-text">你还没有发布过树洞</text>
      <text class="empty-hint">匿名说点什么吧</text>
      <button class="go-publish-btn" bindtap="goToPublish">去发布</button>
    </view>

    <view wx:else class="posts-list">
      <view 
        wx:for="{{myPosts}}" 
        wx:key="id" 
        class="post-card"
      >
        <view class="card-header">
          <view class="mood-tag" style="background: {{item.moodColor}}">
            <text class="emoji">{{item.moodEmoji}}</text>
            <text>{{item.moodName}}</text>
          </view>
          <text class="time">{{item.timeText}}</text>
        </view>
        
        <text class="post-content">{{item.content}}</text>
        
        <view class="card-footer">
          <view class="stats">
            <view class="stat-item">
              <text class="stat-icon">❤️</text>
              <text class="stat-count">{{item.likes}}</text>
            </view>
            <view class="stat-item" bindtap="handleComment" data-post="{{item}}">
              <text class="stat-icon">💬</text>
              <text class="stat-count">{{item.commentCount || 0}}</text>
            </view>
          </view>
          <view class="delete-btn" bindtap="handleDelete" data-id="{{item.id}}">
            <text>🗑️</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<comment-modal 
  visible="{{commentModalVisible}}" 
  post="{{selectedPost}}"
  bind:close="handleCloseComment"
  bind:commented="handleCommented"
/>
