.week-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 24rpx 16rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.nav-icon {
  color: #fff;
  font-size: 40rpx;
  line-height: 1;
}

.week-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.week-num {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.back-today {
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
}

.week-days {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 12rpx 8rpx;
}

.day-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.day-item.today {
  background: rgba(255, 255, 255, 0.3);
}

.day-item.selected {
  background: #fff;
}

.day-weekday {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.day-number {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.day-item.selected .day-weekday,
.day-item.selected .day-number {
  color: #667eea;
}
