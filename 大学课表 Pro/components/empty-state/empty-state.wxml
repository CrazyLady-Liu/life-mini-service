<view class="empty-state">
  <text class="empty-icon">{{icon}}</text>
  <text class="empty-title">{{title}}</text>
  <text wx:if="{{subtitle}}" class="empty-subtitle">{{subtitle}}</text>
  <view 
    wx:if="{{showButton && buttonText}}" 
    class="empty-btn"
    bindtap="onButtonTap"
  >
    {{buttonText}}
  </view>
</view>
