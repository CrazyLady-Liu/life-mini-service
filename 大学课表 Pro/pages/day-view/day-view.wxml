<view class="page-container">
  <view class="date-nav">
    <view class="nav-btn" bindtap="onPrevDay">
      <text class="nav-icon">‹</text>
    </view>
    <view class="date-info" bindtap="onBackToday">
      <text class="date-text">{{currentDateText}}</text>
    </view>
    <view class="nav-btn" bindtap="onNextDay">
      <text class="nav-icon">›</text>
    </view>
  </view>

  <view class="timeline-container">
    <view wx:if="{{courses.length === 0}}" class="no-courses">
      <empty-state 
        icon="😌"
        title="今天没有课程"
        subtitle="享受美好的一天吧~"
        button-text="添加课程"
        show-button="{{true}}"
        bind:buttontap="onAddCourse"
      />
    </view>

    <view wx:else class="timeline" style="height: {{totalHeight}}rpx;">
      <view 
        wx:for="{{timeSlotPositions}}" 
        wx:key="section"
        class="time-slot"
        style="top: {{item.top}}rpx; height: {{item.height}}rpx;"
      >
        <view class="time-marker">
          <text class="time-text">{{item.start}}</text>
          <text class="section-text">第{{item.section}}节</text>
        </view>
        <view class="time-line"></view>
      </view>

      <view class="courses-overlay">
        <block wx:for="{{courses}}" wx:key="id">
          <view 
            class="course-block"
            style="top: {{item._top}}; height: {{item._height}}; background: {{item._bgColor}}; border-left-color: {{item._borderColor}};"
            data-course="{{item}}"
            bindtap="onCourseTap"
          >
            <text class="block-name" style="color: {{item._textColor}};">{{item.name}}</text>
            <text wx:if="{{item.classroom}}" class="block-location">📍 {{item.classroom}}</text>
            <text wx:if="{{item.teacher}}" class="block-teacher">👨‍🏫 {{item.teacher}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
