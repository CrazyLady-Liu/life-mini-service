.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
}

.week-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.week-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.nav-icon {
  font-size: 36rpx;
  color: #666;
}

.week-display {
  display: flex;
  align-items: baseline;
  padding: 0 48rpx;
}

.week-label {
  font-size: 28rpx;
  color: #666;
}

.week-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin: 0 8rpx;
}

.week-picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.picker-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  max-width: 500rpx;
}

.picker-input {
  width: 100%;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.picker-btns {
  display: flex;
  gap: 16rpx;
}

.picker-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}

.picker-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.picker-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.overview-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
}

.overview-divider {
  width: 1rpx;
  background: #eee;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.day-chart {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.day-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  width: 40rpx;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  margin-bottom: 12rpx;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  transition: height 0.3s ease;
}

.day-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.day-count {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
}

.course-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.course-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.course-item:last-child {
  border-bottom: none;
}

.course-color {
  width: 12rpx;
  height: 48rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.course-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.course-teacher {
  font-size: 24rpx;
  color: #999;
}

.course-count {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.count-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

.count-unit {
  font-size: 24rpx;
  color: #999;
}

.suggestion-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.suggestion-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.suggestion-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.empty-stats {
  background: #fff;
  border-radius: 16rpx;
}
