<view class="page-container">
  <view class="user-header">
    <view class="avatar">
      <text class="avatar-icon">📚</text>
    </view>
    <view class="user-info">
      <text class="user-name">大学课表 Pro</text>
      <text class="user-desc">已记录 {{courseCount}} 门课程</text>
    </view>
  </view>

  <view class="action-buttons">
    <view class="action-btn" bindtap="onAddCourse">
      <text class="action-icon">➕</text>
      <text class="action-text">添加课程</text>
    </view>
    <view class="action-btn" bindtap="onImportCourse">
      <text class="action-icon">📥</text>
      <text class="action-text">导入课表</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">🔔 上课提醒</view>
    <view class="setting-card">
      <view class="setting-item">
        <view class="item-info">
          <text class="item-name">上课提醒</text>
          <text class="item-desc">课前自动发送提醒</text>
        </view>
        <switch 
          checked="{{settings.reminderEnabled}}" 
          bindchange="onReminderToggle"
          color="#667eea"
        />
      </view>

      <view wx:if="{{settings.reminderEnabled}}" class="setting-item">
        <view class="item-info">
          <text class="item-name">提前提醒</text>
          <text class="item-desc">课前多少分钟提醒</text>
        </view>
        <picker 
          range="{{reminderTimeOptions}}" 
          value="{{_reminderTimeIndex}}"
          bindchange="onReminderTimeChange"
        >
          <view class="picker-value">
            {{settings.reminderTime}}分钟
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view wx:if="{{settings.reminderEnabled}}" class="setting-item">
        <view class="item-info">
          <text class="item-name">震动提醒</text>
          <text class="item-desc">提醒时伴随震动</text>
        </view>
        <switch 
          checked="{{settings.reminderVibrate}}" 
          bindchange="onVibrateToggle"
          color="#667eea"
        />
      </view>

      <view wx:if="{{settings.reminderEnabled}}" class="setting-item">
        <view class="item-info">
          <text class="item-name">铃声提醒</text>
          <text class="item-desc">提醒时播放提示音</text>
        </view>
        <switch 
          checked="{{settings.reminderSound}}" 
          bindchange="onSoundToggle"
          color="#667eea"
        />
      </view>

      <view wx:if="{{settings.reminderEnabled}}" class="setting-item" bindtap="onTestReminder">
        <view class="item-info">
          <text class="item-name">测试提醒</text>
          <text class="item-desc">预览提醒效果</text>
        </view>
        <text class="link-text">测试 ›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">📅 学期设置</view>
    <view class="setting-card">
      <view class="setting-item" bindtap="onToggleTermPicker">
        <view class="item-info">
          <text class="item-name">开学日期</text>
          <text class="item-desc">{{settings.termStartDate || '未设置'}}</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>
      <view class="setting-item">
        <view class="item-info">
          <text class="item-name">学期总周数</text>
          <text class="item-desc">{{settings.totalWeeks}}周</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showTermPicker}}" class="term-picker-popup">
    <view class="picker-mask" bindtap="onToggleTermPicker"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">学期设置</text>
        <text class="picker-close" bindtap="onToggleTermPicker">✕</text>
      </view>
      <view class="picker-body">
        <view class="form-item">
          <text class="form-label">开学日期</text>
          <picker 
            mode="date" 
            value="{{tempTermStartDate}}" 
            bindchange="onTermStartChange"
          >
            <view class="form-input">
              {{tempTermStartDate || '请选择日期'}}
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">总周数</text>
          <input 
            class="form-input"
            type="number"
            value="{{tempTotalWeeks}}"
            bindinput="onTotalWeeksInput"
            placeholder="输入总周数"
          />
        </view>
      </view>
      <view class="picker-footer">
        <view class="picker-btn confirm" bindtap="onSaveTermSettings">保存</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">🎨 显示设置</view>
    <view class="setting-card">
      <view class="setting-item">
        <view class="item-info">
          <text class="item-name">配色方案</text>
          <text class="item-desc">课程颜色分配方式</text>
        </view>
        <picker 
          range="{{colorModeNames}}" 
          value="{{_colorModeIndex}}"
          bindchange="onColorModeChange"
        >
          <view class="picker-value">
            {{colorModeNames[_colorModeIndex]}}
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      
      <view class="setting-item" bindtap="onRegenerateColors">
        <view class="item-info">
          <text class="item-name">重新分配颜色</text>
          <text class="item-desc">为所有课程重新生成颜色</text>
        </view>
        <text class="link-text">重新生成 ›</text>
      </view>

      <view class="setting-item">
        <view class="item-info">
          <text class="item-name">节次高度</text>
          <text class="item-desc">日视图中每节课的高度</text>
        </view>
        <picker 
          range="{{timeSlotHeightOptions}}" 
          value="{{_timeSlotHeightIndex}}"
          bindchange="onTimeSlotHeightChange"
        >
          <view class="picker-value">
            {{settings.timeSlotHeight}}rpx
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="setting-item" bindtap="onResetTimeSlots">
        <view class="item-info">
          <text class="item-name">重置节次时间</text>
          <text class="item-desc">恢复默认的作息时间配置</text>
        </view>
        <text class="link-text">重置 ›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">📦 数据管理</view>
    <view class="setting-card">
      <view class="setting-item" bindtap="onExportData">
        <view class="item-info">
          <text class="item-name">导出数据</text>
          <text class="item-desc">导出所有课程和设置</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="onImportData">
        <view class="item-info">
          <text class="item-name">导入数据</text>
          <text class="item-desc">从备份数据恢复</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>
      <view class="setting-item danger" bindtap="onClearAllData">
        <view class="item-info">
          <text class="item-name">清空所有数据</text>
          <text class="item-desc">删除所有课程记录</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="setting-card">
      <view class="setting-item" bindtap="onAbout">
        <view class="item-info">
          <text class="item-name">关于</text>
          <text class="item-desc">版本信息与说明</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">无需登录 · 本地存储 · 保护隐私</text>
  </view>
</view>
