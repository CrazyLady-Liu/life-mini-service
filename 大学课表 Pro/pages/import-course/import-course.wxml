<view class="page-container">
  <view class="type-tabs">
    <view 
      class="tab-item {{importType === 'text' ? 'active' : ''}}"
      data-type="text"
      bindtap="onTypeChange"
    >
      <text class="tab-icon">📝</text>
      <text class="tab-text">文本粘贴</text>
    </view>
    <view 
      class="tab-item {{importType === 'excel' ? 'active' : ''}}"
      data-type="excel"
      bindtap="onTypeChange"
    >
      <text class="tab-icon">📊</text>
      <text class="tab-text">Excel导入</text>
    </view>
  </view>

  <view wx:if="{{importType === 'text'}}" class="import-section">
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">粘贴课表信息</text>
        <view class="section-actions">
          <view class="action-link" bindtap="onPasteFromClipboard">粘贴</view>
          <view class="action-link" bindtap="onClearInput">清空</view>
          <view class="action-link" bindtap="onDemoData">示例</view>
        </view>
      </view>
      <textarea 
        class="import-textarea"
        placeholder="粘贴教务系统课表或手动输入&#10;格式示例：&#10;高等数学 周一 1-2节 张老师 教学楼A101&#10;大学英语 周三 3-4节 李老师 外语楼B202"
        value="{{inputText}}"
        bindinput="onTextInput"
        auto-height
        maxlength="2000"
      />
      <view class="parse-btn" bindtap="onParseText">
        <text>🔍 智能识别课程</text>
      </view>
    </view>
  </view>

  <view wx:if="{{importType === 'excel'}}" class="import-section">
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">选择Excel文件</text>
      </view>
      <view class="file-upload-area" bindtap="onChooseFile">
        <text class="upload-icon">📁</text>
        <text class="upload-text">点击选择Excel/CSV文件</text>
        <text class="upload-hint">支持 .xls, .xlsx, .csv 格式</text>
      </view>
    </view>
  </view>

  <view wx:if="{{isParsed}}" class="result-section">
    <view class="result-header">
      <view class="result-info">
        <text class="result-title">解析结果</text>
        <text class="result-count">共 {{parsedCourses.length}} 门课程</text>
      </view>
      <view class="select-all" bindtap="onSelectAll">
        {{selectedCourses.length === parsedCourses.length ? '取消全选' : '全选'}}
      </view>
    </view>

    <view wx:if="{{parsedCourses.length === 0}}" class="empty-result">
      <empty-state 
        icon="😅"
        title="未能识别课程"
        subtitle="请检查输入格式是否正确"
      />
    </view>

    <view wx:else class="parsed-list">
      <view 
        wx:for="{{parsedCourses}}" 
        wx:key="index"
        class="parsed-item {{item._selected ? 'selected' : ''}}"
        data-index="{{index}}"
        bindtap="onCourseToggle"
      >
        <view class="checkbox">
          <text wx:if="{{item._selected}}" class="check-icon">✓</text>
        </view>
        <view class="item-content">
          <view class="item-header">
            <text class="item-name" style="color: {{courseColors[item.name] || '#667eea'}};">{{item.name || '未命名课程'}}</text>
            <text wx:if="{{item.weekday}}" class="item-weekday">周{{['一','二','三','四','五','六','日'][item.weekday-1]}}</text>
          </view>
          <view class="item-meta">
            <text wx:if="{{item.sections.length}}" class="meta-item">第{{item.sections}}节</text>
            <text wx:if="{{item.teacher}}" class="meta-item">👨‍🏫 {{item.teacher}}</text>
            <text wx:if="{{item.classroom}}" class="meta-item">📍 {{item.classroom}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="import-footer">
      <view class="import-info">
        已选择 <text class="highlight">{{selectedCourses.length}}</text> 门课程
      </view>
      <view class="import-btn" bindtap="onImport">
        导入选中课程
      </view>
    </view>
  </view>
</view>
