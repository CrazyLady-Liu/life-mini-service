<view class="page-container">
  <view class="form-card">
    <view class="form-row">
      <text class="row-label">课程名称</text>
      <input 
        class="row-input" 
        placeholder="请输入课程名称" 
        value="{{name}}" 
        bindinput="onNameInput"
        maxlength="50"
      />
    </view>

    <view class="form-row">
      <text class="row-label">任课教师</text>
      <input 
        class="row-input" 
        placeholder="请输入教师姓名（选填）" 
        value="{{teacher}}" 
        bindinput="onTeacherInput"
        maxlength="20"
      />
    </view>

    <view class="form-row">
      <text class="row-label">上课教室</text>
      <input 
        class="row-input" 
        placeholder="请输入教室位置（选填）" 
        value="{{classroom}}" 
        bindinput="onClassroomInput"
        maxlength="30"
      />
    </view>

    <view class="form-row">
      <text class="row-label">星期</text>
      <picker 
        mode="selector" 
        range="{{weekdayOptions}}" 
        value="{{weekday - 1}}" 
        bindchange="onWeekdayChange"
      >
        <view class="picker-display">
          {{weekdayOptions[weekday - 1]}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-row column">
      <text class="row-label">节次</text>
      <view class="section-grid">
        <view 
          wx:for="{{sectionOptions}}" 
          wx:key="value"
          class="section-item {{item._selected ? 'selected' : ''}}"
          data-value="{{index}}"
          bindtap="onSectionToggle"
        >
          <text>第{{item.value}}节</text>
        </view>
      </view>
    </view>

    <view class="form-row">
      <text class="row-label">周次</text>
      <input 
        class="row-input" 
        placeholder="如：1-8,10-16" 
        value="{{weekRangeInput}}" 
        bindinput="onWeekRangeInput"
      />
    </view>

    <view class="form-row column">
      <text class="row-label">课程颜色</text>
      <view class="color-grid">
        <view 
          wx:for="{{colorOptions}}" 
          wx:key="*this"
          class="color-item {{color === item ? 'selected' : ''}}"
          style="background: {{item}};"
          data-color="{{item}}"
          bindtap="onColorSelect"
        >
          <text wx:if="{{color === item}}" class="color-check">✓</text>
        </view>
      </view>
    </view>

    <view class="form-row column">
      <text class="row-label">备注</text>
      <textarea 
        class="row-textarea" 
        placeholder="添加备注信息（选填）" 
        value="{{note}}" 
        bindinput="onNoteInput"
        maxlength="200"
        auto-height
      />
    </view>
  </view>

  <view class="action-buttons">
    <view wx:if="{{isEdit}}" class="btn btn-danger" bindtap="onDelete">删除课程</view>
    <view class="btn btn-primary btn-block" bindtap="onSave">
      {{isEdit ? '保存修改' : '添加课程'}}
    </view>
  </view>
</view>

<view class="quick-fill-btn" bindtap="onQuickFill">
  <text class="quick-icon">✨</text>
  <text class="quick-text">智能识别</text>
</view>
