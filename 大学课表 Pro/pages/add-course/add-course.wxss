.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx 24rpx 120rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.form-row.column {
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
}

.row-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.row-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.row-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.picker-display {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.section-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
}

.section-item {
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s ease;
}

.section-item.selected {
  background: #667eea;
  color: #fff;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
}

.color-item.selected {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.color-check {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.action-buttons {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-danger {
  background: #fee;
  color: #ee0a24;
  border: 1rpx solid #ffcccc;
}

.btn-block {
  width: 100%;
}

.quick-fill-btn {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 32rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.quick-icon {
  font-size: 32rpx;
}

.quick-text {
  color: #fff;
  font-size: 26rpx;
}
