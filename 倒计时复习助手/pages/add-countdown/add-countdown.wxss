.add-container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #F8F9FC;
  display: flex;
  flex-direction: column;
}

.page-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #5A6C7D;
  margin-bottom: 40rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
  flex: 1;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8AA3BD;
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: #F5F8FC;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #5A6C7D;
  box-sizing: border-box;
  text-align: center;
  border: 2rpx solid #E8EEF5;
}

.input-placeholder {
  color: #B8C8D8;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.placeholder {
  color: #B8C8D8;
}

.picker-arrow {
  font-size: 28rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.tag-item {
  flex: 1;
  min-width: 140rpx;
  max-width: 160rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F8FC;
  border: 2rpx solid #E8EEF5;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.tag-item.active {
  background: #A8D5BA;
  border-color: #A8D5BA;
}

.tag-label {
  font-size: 26rpx;
  color: #8AA3BD;
}

.tag-item.active .tag-label {
  color: #FFFFFF;
  font-weight: 500;
}

.submit-section {
  padding: 50rpx 20rpx 30rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #A8D5BA;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}
