.plan-container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 120rpx;
  background: #F8F9FC;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
}

.date-nav {
  width: 64rpx;
  height: 64rpx;
  background: #F5F8FC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 36rpx;
  color: #7BA3C7;
  line-height: 1;
}

.date-display {
  text-align: center;
}

.date-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #5A6C7D;
  margin-bottom: 4rpx;
}

.date-value {
  font-size: 24rpx;
  color: #A3B8CC;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #7BA3C7;
  margin-bottom: 8rpx;
  text-align: center;
}

.stat-number.green {
  color: #88C9A1;
}

.stat-label {
  font-size: 24rpx;
  color: #A3B8CC;
  text-align: center;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #F0F4F8;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(173, 196, 222, 0.12);
  transition: all 0.3s;
}

.plan-card.completed {
  opacity: 0.6;
  background: #FAFBFD;
}

.plan-checkbox {
  margin-right: 24rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #D4E0EB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.checkbox.checked {
  background: #A8D5BA;
  border-color: #A8D5BA;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}

.plan-content {
  flex: 1;
}

.plan-subject {
  font-size: 28rpx;
  font-weight: 500;
  color: #7BA3C7;
  margin-bottom: 8rpx;
  display: block;
  text-align: center;
}

.plan-card.completed .plan-subject {
  text-decoration: line-through;
}

.plan-detail {
  font-size: 26rpx;
  color: #5A6C7D;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: center;
}

.plan-card.completed .plan-detail {
  text-decoration: line-through;
}

.plan-actions {
  margin-left: 20rpx;
}

.delete-btn {
  font-size: 22rpx;
  color: #C8D4E0;
  padding: 8rpx 16rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8AA3BD;
  display: block;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 24rpx 60rpx;
  background: #A8D5BA;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.add-fab {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: #A8D5BA;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(168, 213, 186, 0.4);
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  line-height: 1;
}
