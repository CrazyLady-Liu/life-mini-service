.add-container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #F8F9FC;
  display: flex;
  flex-direction: column;
}

.page-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #5A6C7D;
  margin-bottom: 40rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
  flex: 1;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8AA3BD;
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 92rpx;
  padding: 0 28rpx;
  background: #F5F8FC;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #5A6C7D;
  box-sizing: border-box;
  text-align: center;
  border: 2rpx solid #E8EEF5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-input.disabled {
  color: #8AA3BD;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 28rpx;
  background: #F5F8FC;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #5A6C7D;
  box-sizing: border-box;
  text-align: center;
  border: 2rpx solid #E8EEF5;
  line-height: 1.6;
}

.input-placeholder {
  color: #B8C8D8;
}

.subject-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}

.subject-item {
  padding: 16rpx 32rpx;
  background: #F5F8FC;
  border: 2rpx solid #E8EEF5;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #8AA3BD;
  transition: all 0.3s;
}

.subject-item.active {
  background: #A8D5BA;
  border-color: #A8D5BA;
  color: #FFFFFF;
}

.or-divider {
  text-align: center;
  margin: 20rpx 0;
}

.or-text {
  font-size: 24rpx;
  color: #B8C8D8;
  background: #F8F9FC;
  padding: 0 20rpx;
}

.submit-section {
  padding: 50rpx 20rpx 30rpx;
}

.btn-primary {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: #A8D5BA;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}
