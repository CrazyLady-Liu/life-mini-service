.detail-container {
  min-height: 100vh;
  background: #F8F9FC;
}

.hero-section {
  background: #E8F0F7;
  padding: 80rpx 40rpx 100rpx;
  text-align: center;
  border-radius: 0 0 48rpx 48rpx;
}

.days-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
}

.days-number {
  font-size: 140rpx;
  font-weight: bold;
  color: #7BA3C7;
  line-height: 1;
}

.days-label {
  font-size: 32rpx;
  color: #8AA3BD;
  margin-left: 12rpx;
}

.status-wrap {
  display: flex;
  justify-content: center;
}

.status-badge {
  padding: 12rpx 36rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.status-badge.normal {
  background: #FFFFFF;
  color: #88C9A1;
}

.status-badge.urgent {
  background: #FFE8E8;
  color: #F4A7A7;
}

.status-badge.today {
  background: #FFF4E6;
  color: #E89F5B;
}

.status-badge.week {
  background: #F0E6FF;
  color: #A58BE8;
}

.status-badge.expired {
  background: #F0F2F5;
  color: #A3B8CC;
}

.info-section {
  padding: 0 30rpx;
  margin-top: -50rpx;
}

.info-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 10rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.info-label {
  font-size: 24rpx;
  color: #A3B8CC;
  margin-bottom: 12rpx;
  text-align: center;
}

.info-value {
  font-size: 30rpx;
  color: #5A6C7D;
  text-align: center;
  word-break: break-all;
  font-weight: 500;
}

.info-divider {
  height: 2rpx;
  background: #F0F4F8;
}

.action-section {
  padding: 60rpx 60rpx;
}

.delete-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: #FFFFFF;
  color: #F4A7A7;
  border: 3rpx solid #F4C7C7;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.delete-btn::after {
  border: none;
}
