<view class="login-container">
  <view class="login-header">
    <view class="logo-wrap">
      <text class="logo">📚</text>
    </view>
    <text class="title">倒计时复习助手</text>
    <text class="subtitle">科学规划 · 高效复习</text>
  </view>
  
  <view class="login-form">
    <view class="form-item">
      <text class="form-label">学号</text>
      <input 
        class="form-input" 
        placeholder="请输入学号" 
        placeholder-class="input-placeholder"
        value="{{studentId}}" 
        bindinput="onInputStudentId"
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">密码</text>
      <input 
        class="form-input" 
        placeholder="请输入密码" 
        placeholder-class="input-placeholder"
        password="{{true}}" 
        value="{{password}}" 
        bindinput="onInputPassword"
      />
    </view>
    
    <button class="btn-primary" bindtap="onLogin">登 录</button>
    
    <view class="register-link">
      <text>还没有账号？</text>
      <text class="link-text" bindtap="onGoToRegister">家长注册入口</text>
    </view>
  </view>
</view>
