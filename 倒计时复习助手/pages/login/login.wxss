.login-container {
  min-height: 100vh;
  background: #F8F9FC;
  display: flex;
  flex-direction: column;
}

.login-header {
  background: #E8F0F7;
  padding: 100rpx 40rpx 80rpx;
  text-align: center;
  border-radius: 0 0 60rpx 60rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #FFFFFF;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.25);
}

.logo {
  font-size: 80rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #5A6C7D;
  margin-bottom: 12rpx;
  text-align: center;
}

.subtitle {
  font-size: 26rpx;
  color: #8AA3BD;
  text-align: center;
  display: block;
}

.login-form {
  flex: 1;
  background: #FFFFFF;
  margin: 40rpx 30rpx;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8AA3BD;
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: #F5F8FC;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #5A6C7D;
  box-sizing: border-box;
  text-align: center;
  border: 2rpx solid #E8EEF5;
}

.input-placeholder {
  color: #B8C8D8;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #A8D5BA;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 20rpx;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.register-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #A3B8CC;
}

.link-text {
  color: #7BA3C7;
  margin-left: 8rpx;
}
