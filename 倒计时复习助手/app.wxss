page {
  background-color: #F8F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #5A6C7D;
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(173, 196, 222, 0.15);
}

.btn-primary {
  background: #A8D5BA;
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #E8F0F7;
  color: #7BA3C7;
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

.btn-outline {
  background: #FFFFFF;
  color: #F4A7A7;
  border: 3rpx solid #F4C7C7;
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8AA3BD;
  margin-bottom: 16rpx;
  display: block;
  text-align: center;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: #F5F8FC;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #5A6C7D;
  box-sizing: border-box;
  text-align: center;
  border: 2rpx solid #E8EEF5;
}

.tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  margin: 0 8rpx;
}

.tag-homework {
  background: #FFF4E6;
  color: #E89F5B;
}

.tag-midterm {
  background: #FFE8E8;
  color: #E88B8B;
}

.tag-final {
  background: #F0E6FF;
  color: #A58BE8;
}

.tag-cet {
  background: #E6F7EC;
  color: #6BBF8E;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #A3B8CC;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-text {
  font-size: 28rpx;
  display: block;
}

.section-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #5A6C7D;
  margin-bottom: 28rpx;
  display: block;
}
