page {
  background-color: #F5F5F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: #4A7C59;
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary:active {
  background-color: #3A6C49;
}

.btn-secondary {
  background-color: #fff;
  color: #4A7C59;
  border: 2rpx solid #4A7C59;
  border-radius: 48rpx;
  padding: 18rpx 48rpx;
  font-size: 30rpx;
}

.btn-disabled {
  background-color: #ccc;
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  border: none;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-exchange {
  background-color: #E8F5E9;
  color: #4A7C59;
}

.tag-borrow {
  background-color: #FFF3E0;
  color: #F57C00;
}

.tag-both {
  background-color: #E3F2FD;
  color: #1976D2;
}

.tag-available {
  background-color: #E8F5E9;
  color: #4A7C59;
}

.tag-pending {
  background-color: #FFF3E0;
  color: #F57C00;
}

.tag-borrowed {
  background-color: #FFEBEE;
  color: #C62828;
}

.tag-exchanged {
  background-color: #F3E5F5;
  color: #7B1FA2;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #bbb;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4A7C59;
  background-color: #fff;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
  min-height: 180rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
