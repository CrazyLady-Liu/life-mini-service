.detail-container {
  padding-bottom: 160rpx;
}

.cover-swiper {
  width: 100%;
  height: 500rpx;
}

.cover-wrap {
  width: 100%;
  height: 100%;
  position: relative;
}

.cover-image {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
}

.cover-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A7C59 0%, #6B9B7A 100%);
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #fff;
  text-align: center;
  padding: 0 40rpx;
}

.book-info {
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
  margin: -40rpx 24rpx 24rpx;
  padding: 32rpx;
}

.book-header {
  margin-bottom: 16rpx;
}

.book-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.book-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.book-author {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.book-condition {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.book-period {
  font-size: 26rpx;
  color: #F57C00;
}

.owner-info {
  margin: 0 24rpx 24rpx;
}

.owner-header {
  display: flex;
  align-items: center;
}

.owner-avatar {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #F5F5F0;
  border-radius: 50%;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.owner-detail {
  flex: 1;
}

.owner-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
}

.book-description {
  margin: 0 24rpx 24rpx;
}

.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  flex: 1;
  margin: 0;
}

.request-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  margin: 0;
}
