.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background: #4A7C59;
  color: #fff;
  font-weight: 500;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-item {
  padding: 24rpx;
}

.record-header {
  display: flex;
  margin-bottom: 20rpx;
}

.cover-wrap {
  position: relative;
  width: 120rpx;
  height: 160rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.book-cover {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.cover-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A7C59 0%, #6B9B7A 100%);
  border-radius: 8rpx;
}

.placeholder-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.placeholder-text {
  font-size: 16rpx;
  color: #fff;
  text-align: center;
  padding: 0 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.record-type {
  margin-bottom: 8rpx;
}

.record-partners {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

.record-detail {
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.detail-label {
  color: #999;
}

.detail-value {
  color: #333;
}

.tag-returned {
  background-color: #E8F5E9;
  color: #4A7C59;
}

.tag-active {
  background-color: #FFF3E0;
  color: #F57C00;
}
