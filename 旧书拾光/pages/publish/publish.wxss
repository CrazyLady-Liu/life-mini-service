.cover-upload {
  width: 200rpx;
  height: 260rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
  overflow: hidden;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
}

.images-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.image-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #FAFAFA;
  color: #333;
}

.picker-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.type-options {
  display: flex;
  gap: 24rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  background: #FAFAFA;
  transition: all 0.2s;
}

.type-option.active {
  border-color: #4A7C59;
  background: #E8F5E9;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-text {
  font-size: 26rpx;
  color: #666;
}

.type-option.active .type-text {
  color: #4A7C59;
  font-weight: 500;
}

.submit-btn {
  width: 100%;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}
