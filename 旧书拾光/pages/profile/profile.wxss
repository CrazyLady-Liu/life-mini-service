.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A7C59 0%, #6B9B7A 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 60rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.8;
}

.edit-btn {
  padding: 8rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 32rpx;
  font-size: 24rpx;
}

.stats-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 600;
  color: #4A7C59;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  background: #F0F0F0;
}

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #E53935;
  color: #fff;
  border-radius: 18rpx;
  font-size: 22rpx;
  padding: 0 10rpx;
  margin-right: 12rpx;
}

.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.edit-input {
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  margin: 0;
}

.about-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-content {
  position: relative;
  width: 620rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.about-header {
  background: linear-gradient(135deg, #4A7C59 0%, #6B9B7A 100%);
  padding: 48rpx 32rpx 40rpx;
  text-align: center;
  color: #fff;
}

.about-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.about-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.about-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  letter-spacing: 2rpx;
}

.about-body {
  padding: 32rpx;
  flex: 1;
  overflow-y: auto;
}

.about-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 32rpx;
  text-align: justify;
}

.about-features {
  background: #F8F9F5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A7C59;
  margin-bottom: 20rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.feature-text {
  flex: 1;
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.about-slogan {
  font-size: 28rpx;
  color: #4A7C59;
  font-weight: 500;
  text-align: center;
  line-height: 1.8;
  padding: 16rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 12rpx;
}

.about-footer {
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
}

.about-close-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4A7C59 0%, #6B9B7A 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.about-close-btn:active {
  opacity: 0.9;
}
