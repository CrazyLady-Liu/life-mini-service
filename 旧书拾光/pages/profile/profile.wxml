<view class="container">
  <view class="user-card">
    <view class="user-avatar">{{userInfo.avatar || '📖'}}</view>
    <view class="user-info">
      <view class="user-name">{{userInfo.name}}</view>
      <view class="user-id">ID: {{userInfo.id}}</view>
    </view>
    <view class="edit-btn" bindtap="editProfile">
      <text>编辑</text>
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item" bindtap="goToMyBooks">
      <view class="stat-number">{{stats.books}}</view>
      <view class="stat-label">我的书籍</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-number">{{stats.exchanges}}</view>
      <view class="stat-label">完成交换</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-number">{{stats.borrows}}</view>
      <view class="stat-label">完成借阅</view>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goToMyBooks">
      <view class="menu-left">
        <text class="menu-icon">📚</text>
        <text class="menu-text">我的书单</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToRequests">
      <view class="menu-left">
        <text class="menu-icon">📩</text>
        <text class="menu-text">申请管理</text>
      </view>
      <view class="menu-right">
        <view class="badge" wx:if="{{pendingCount > 0}}">{{pendingCount}}</view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="goToRecords">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-text">流转记录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">🌱</text>
        <text class="menu-text">绿色环保</text>
      </view>
      <view class="menu-right">
        <text class="menu-desc">已节约 {{stats.books * 2}} 张纸</text>
      </view>
    </view>

    <view class="menu-item" bindtap="showAboutModal">
      <view class="menu-left">
        <text class="menu-icon">💚</text>
        <text class="menu-text">关于旧书拾光</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>

<view class="about-modal" wx:if="{{showAboutModal}}">
  <view class="modal-mask" bindtap="hideAboutModal"></view>
  <view class="about-content">
    <view class="about-header">
      <text class="about-icon">📚</text>
      <view class="about-title">旧书拾光</view>
      <view class="about-subtitle">让闲置好书流转起来</view>
    </view>
    <view class="about-body">
      <view class="about-desc">
        旧书拾光是一款二手书籍交换、借阅公益工具小程序，致力于让闲置好书流转起来，实现书籍循环利用、绿色环保。
      </view>
      <view class="about-features">
        <view class="feature-title">你可以在这里：</view>
        <view class="feature-item">
          <text class="feature-icon">📖</text>
          <text class="feature-text">发布闲置书籍，支持交换/借阅两种流转方式</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">👀</text>
          <text class="feature-text">浏览他人好书，发起交换或借阅申请</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">📝</text>
          <text class="feature-text">记录每一次书籍流转，遇见同频书友</text>
        </view>
      </view>
      <view class="about-slogan">
        愿每一本旧书，都能遇见新读者，延续文字的温度
      </view>
    </view>
    <view class="about-footer">
      <button class="btn-primary about-close-btn" bindtap="hideAboutModal">我知道了</button>
    </view>
  </view>
</view>

<view class="edit-modal" wx:if="{{showEditModal}}">
  <view class="modal-mask" bindtap="hideEditModal"></view>
  <view class="modal-content">
    <view class="modal-title">修改昵称</view>
    <input class="form-input edit-input" placeholder="请输入新昵称" value="{{editName}}" bindinput="onEditInput" />
    <view class="modal-actions">
      <button class="btn-secondary modal-btn" bindtap="hideEditModal">取消</button>
      <button class="btn-primary modal-btn" bindtap="saveProfile">保存</button>
    </view>
  </view>
</view>
