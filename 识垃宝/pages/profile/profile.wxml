<view class="container">
  <view class="profile-header">
    <view class="avatar">
      <text class="avatar-icon">👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.phone}}</text>
      <text class="login-time">登录时间: {{userInfo.loginTime}}</text>
    </view>
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goCategory">
      <text class="menu-icon">📚</text>
      <text class="menu-text">分类标准</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">查询历史</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="showFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="category-section">
    <text class="section-title">垃圾分类标准</text>
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="key" 
        class="category-card"
        bindtap="goDetail"
        data-category="{{item.key}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <view class="category-content">
          <text class="category-name">{{item.name}}</text>
          <text class="category-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="version">识垃宝 v1.0.0</text>
    <text class="copyright">让垃圾分类更简单</text>
  </view>
</view>