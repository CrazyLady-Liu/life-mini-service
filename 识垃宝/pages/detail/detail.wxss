.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.detail-header {
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
}

.detail-icon {
  font-size: 80rpx;
  margin-right: 30rpx;
}

.detail-title {
  display: flex;
  flex-direction: column;
}

.title-name {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.title-category {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.detail-content {
  padding: 30rpx;
  margin-top: -30rpx;
}

.card {
  background-color: white;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-body {
  padding: 28rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.tip-text {
  font-size: 28rpx;
  color: #4CAF50;
  line-height: 1.8;
}

.notes-list {
  padding-left: 10rpx;
}

.note-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.note-item:last-child {
  margin-bottom: 0;
}

.note-dot {
  color: #4CAF50;
  font-size: 28rpx;
  margin-right: 16rpx;
  line-height: 1.6;
}

.note-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.similar-list {
  padding-left: 10rpx;
}

.similar-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.similar-item:last-child {
  border-bottom: none;
}

.similar-name {
  font-size: 28rpx;
  color: #333;
}

.similar-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.similar-item:active {
  background-color: #f9f9f9;
}

.detail-content .card:first-child {
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
}