.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.camera-section {
  margin-bottom: 24rpx;
}

.camera-box {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(76, 175, 80, 0.35);
  position: relative;
  overflow: hidden;
}

.camera-box::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.camera-box::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.camera-icon {
  font-size: 140rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.camera-text {
  font-size: 44rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.camera-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  position: relative;
  z-index: 1;
}

.search-section {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  background-color: white;
  border-radius: 48rpx;
  padding: 12rpx 12rpx 12rpx 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.search-box input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
}

.search-btn {
  width: 88rpx;
  height: 88rpx;
  background-color: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.search-btn text {
  font-size: 40rpx;
}

.quick-section {
  margin-bottom: 24rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  background-color: white;
  padding: 20rpx 36rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #555;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hot-tag:active {
  background-color: #4CAF50;
  color: white;
  transform: scale(0.96);
}

.category-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(50% - 8rpx);
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  border-left: 6rpx solid;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.category-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.result-section {
  margin-top: 24rpx;
}

.result-card {
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.result-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.result-info {
  display: flex;
  flex-direction: column;
}

.result-name {
  font-size: 38rpx;
  font-weight: bold;
  color: white;
}

.result-category {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.result-content {
  padding: 28rpx 32rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.result-tip {
  background-color: #f8f9fa;
  padding: 18rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
}

.result-tip text:last-child {
  font-size: 26rpx;
  color: #888;
}

.camera-box:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.category-item:active {
  transform: scale(0.98);
}