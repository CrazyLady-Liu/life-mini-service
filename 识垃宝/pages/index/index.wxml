<view class="container">
  <view class="camera-section">
    <view class="camera-box" bindtap="takePhoto">
      <view class="camera-icon">📷</view>
      <text class="camera-text">拍照识垃圾</text>
      <text class="camera-hint">拍照 / 上传图片一键识别</text>
    </view>
  </view>

  <view class="search-section">
    <view class="search-box">
      <input 
        type="text" 
        placeholder="搜索垃圾名称" 
        value="{{keyword}}" 
        bindinput="onKeywordInput"
        bindconfirm="search"
      />
      <button class="search-btn" bindtap="search">
        <text>🔍</text>
      </button>
    </view>
  </view>

  <view class="quick-section">
    <view class="hot-tags">
      <view 
        wx:for="{{hotKeywords}}" 
        wx:key="*this" 
        class="hot-tag" 
        bindtap="searchByTag"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="category-section">
    <text class="section-title">分类速查</text>
    <view class="category-grid">
      <view 
        wx:for="{{categories}}" 
        wx:key="key" 
        class="category-item"
        style="border-left-color: {{item.color}}"
        bindtap="showCategoryDetail"
        data-category="{{item.key}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="result-section" wx:if="{{result}}">
    <view class="result-card" bindtap="goDetail">
      <view class="result-header" style="background-color: {{result.categoryInfo.color}}">
        <text class="result-icon">{{result.categoryInfo.icon}}</text>
        <view class="result-info">
          <text class="result-name">{{result.name}}</text>
          <text class="result-category">{{result.categoryInfo.name}}</text>
        </view>
      </view>
      <view class="result-content">
        <text class="result-desc">{{result.categoryInfo.description}}</text>
        <view class="result-tip">
          <text class="tip-icon">💡</text>
          <text>{{result.categoryInfo.tips}}</text>
        </view>
      </view>
    </view>
  </view>
</view>