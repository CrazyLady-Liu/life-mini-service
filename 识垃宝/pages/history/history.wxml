<view class="container">
  <view class="header">
    <text class="title">查询历史</text>
    <button 
      wx:if="{{history.length > 0}}" 
      class="clear-btn" 
      bindtap="clearAll"
    >
      清空记录
    </button>
  </view>

  <view class="history-list" wx:if="{{history.length > 0}}">
    <view 
      wx:for="{{history}}" 
      wx:key="id" 
      class="history-item"
      bindlongpress="showDeleteMenu"
      data-id="{{item.id}}"
    >
      <view class="item-left" bindtap="goDetail" data-item="{{item}}">
        <text class="item-icon">{{item.icon}}</text>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-time">{{item.time}}</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-category">{{item.categoryName}}</text>
        <text class="delete-btn" bindtap="deleteItem" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无查询记录</text>
    <text class="empty-desc">去首页搜索垃圾，记录将保存在这里</text>
    <button class="go-search-btn" bindtap="goSearch">去查询</button>
  </view>
</view>