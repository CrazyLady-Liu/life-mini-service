.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.logo-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-section {
  background-color: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.input-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-item input {
  flex: 1;
  font-size: 30rpx;
}

.code-btn {
  padding: 16rpx 24rpx;
  background-color: #4CAF50;
  color: white;
  border-radius: 32rpx;
  font-size: 26rpx;
  border: none;
}

.remember-section {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.check-icon {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.remember-text {
  font-size: 28rpx;
  color: #666;
}

.btn-primary {
  background-color: #4CAF50;
  color: white;
  border-radius: 40rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 34rpx;
  margin-top: 30rpx;
  border: none;
}

.btn-primary:active {
  background-color: #45a049;
}

.login-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 30rpx;
}

.link {
  color: #4CAF50;
}

.guest-section {
  text-align: center;
}

.guest-btn {
  background: none;
  color: white;
  font-size: 28rpx;
  border: 2rpx solid white;
  border-radius: 32rpx;
  padding: 20rpx 60rpx;
}

.guest-btn:active {
  background-color: rgba(255, 255, 255, 0.2);
}