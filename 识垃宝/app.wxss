page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #4CAF50;
  color: white;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.btn-primary:active {
  background-color: #45a049;
}

.input-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.input-item input {
  flex: 1;
  font-size: 30rpx;
  margin-left: 20rpx;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #999999;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-40 {
  margin-top: 40rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.color-primary {
  color: #4CAF50;
}

.color-danger {
  color: #f44336;
}

.color-warning {
  color: #ff9800;
}

.color-info {
  color: #2196F3;
}